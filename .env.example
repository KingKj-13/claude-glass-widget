# Optional overrides for budgets / estimation. Copy to `.env` or set these in
# your environment. All are read by the Rust backend at refresh time.
#
# Token figures count GENERATED tokens (input + output + cache writes) and
# exclude cache READS, which are cheap reuse and otherwise dominate the totals.

# "Available Today" token ceiling (whole tokens).
CLAUDE_DAILY_TOKEN_LIMIT=10000000

# Total budget for the current 5-hour window (drives the "Current Session" bar).
CLAUDE_SESSION_TOKEN_LIMIT=4000000

# Per-model budget for the current 5-hour window (drives the model bars).
CLAUDE_WINDOW_TOKEN_LIMIT=2000000

# Used to estimate the request count shown in the expanded history tables
# (ccusage has no per-message count).
CLAUDE_AVG_TOKENS_PER_REQUEST=1100
