# Optional overrides for plan limits / estimation. Copy to `.env` or set these
# in your environment. All are read by the Rust backend at refresh time.

# "Available Today" token ceiling (whole tokens).
CLAUDE_DAILY_TOKEN_LIMIT=10000000

# Current-session (5h rolling window) token ceiling.
CLAUDE_SESSION_TOKEN_LIMIT=10000000

# Per-model request ceilings.
CLAUDE_SONNET_REQUEST_LIMIT=5000
CLAUDE_OPUS_REQUEST_LIMIT=500

# Used to estimate request counts from token usage (ccusage has no per-message
# count). Lower it for shorter messages, raise it for longer ones.
CLAUDE_AVG_TOKENS_PER_REQUEST=1100
