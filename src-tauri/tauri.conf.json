{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Claude Glass Widget",
  "version": "1.0.0",
  "identifier": "com.claudeglass.widget",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "Claude Glass Widget",
        "width": 400,
        "height": 520,
        "minWidth": 300,
        "minHeight": 360,
        "x": 1100,
        "y": 40,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false,
        "center": false,
        "focus": true,
        "visible": true,
        "fullscreen": false,
        "maximizable": false,
        "minimizable": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: asset: http://asset.localhost; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "copyright": "© 2026 Claude Glass Widget",
    "category": "Utility",
    "shortDescription": "Floating glass HUD for Claude AI usage.",
    "longDescription": "A premium always-on-top glass desktop widget that keeps your Claude AI usage (requests, tokens, sessions and reset countdown) permanently visible, powered by ccusage.",
    "windows": {
      "nsis": {
        "installMode": "perMachine"
      }
    }
  },
  "plugins": {}
}
